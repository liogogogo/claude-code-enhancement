{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_level": "L1 - Minimal",
  "_description": "最小权限模式：仅核心开发命令，适合 CI/CD 或不熟悉的项目",

  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(pip install:*)",
      "Bash(pytest:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(go:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(gh:*)",
      "WebSearch"
    ]
  }
}
